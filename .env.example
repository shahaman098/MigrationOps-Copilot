# Direct Azure OpenAI configuration
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=gpt-4o-mini

# Optional: Azure AI project endpoint / Foundry-compatible endpoint
# AZURE_AI_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/
# AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5-mini

# Optional: API key auth for direct Azure OpenAI mode
# AZURE_OPENAI_API_KEY=your-key-here

# Optional: Hosted MCP discovery URL (public HTTPS for Azure-hosted MCP, or local URL for local testing)
# MCP_SERVER_URL=https://your-mcp-app.azurewebsites.net/mcp

# Optional: Local MCP server settings
# MCP_SERVER_HOST=0.0.0.0
# MCP_SERVER_PORT=8081
# MCP_STREAMABLE_HTTP_PATH=/mcp
